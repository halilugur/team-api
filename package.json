{
  "name": "team-api",
  "productName": "Team API",
  "version": "1.1.3",
  "description": "File-system based HTTP API testing client.",
  "author": "halilugur",
  "license": "Apache-2.0",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "./release.sh"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.4"
  },
  "build": {
    "appId": "com.teamapi.app",
    "productName": "TeamAPI",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "identity": null
    },
    "win": {
      "target": [
        "nsis",
        "msi",
        "zip"
      ],
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png"
    }
  }
}